def solution(players, callings):
    rank = {}
    for i, name in enumerate(players):
        rank[name] = i
        # rank를 만들어서 딕셔너리를 생성함.
        # 이제 순서를 바꿔주면 
    for i in callings:
        a = rank[i] # a는 지금 내이름의 위치
        b = players[a-1]    # b는 내 앞사람 이름
        players[a], players[a-1] = players[a-1], players[a] # players는 바꿔줬고
        rank[i] = a-1
        rank[b] = a
    return players

